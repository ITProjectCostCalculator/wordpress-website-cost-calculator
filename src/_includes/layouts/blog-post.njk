---
layout: layouts/base.njk
---
<main id="blog-post-view" style="padding-top: calc(var(--header-h) + 40px); padding-bottom: 80px;">
    <div class="search-section">
        <div class="calc-header-bar" style="margin-bottom: 40px;">
            <a href="/blog/" class="back-btn">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg> 
                Back to Blog
            </a>
            <div class="calc-breadcrumb">
                <a href="/">Home</a> <span>›</span> 
                <a href="/blog/">Blog</a> <span>›</span> 
                <span>Article</span>
            </div>
        </div>
    </div>

    <article style="max-width: 800px; margin: 0 auto; padding: 0 24px;">
        <header style="margin-bottom: 40px; text-align: center; border-bottom: 1px solid var(--border); padding-bottom: 40px;">
            {% if category %}
            <a href="/blog/category/{{ category | slugify }}/" class="calc-card-category" style="margin-bottom: 20px; display: inline-block; padding: 6px 16px; font-size: 0.8rem; background: rgba(108, 99, 255, 0.1); color: var(--primary); border: 1px solid rgba(108, 99, 255, 0.2);">
                {{ category }}
            </a>
            {% endif %}
            <h1 class="gradient-text" style="font-size: clamp(2.2rem, 5vw, 3.2rem); font-weight: 800; line-height: 1.2; letter-spacing: -0.03em; margin-bottom: 20px;">
                {{ title }}
            </h1>
            <div style="color: var(--text-muted); font-size: 0.95rem; display: flex; align-items: center; justify-content: center; gap: 8px;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                Published on {{ page.date | date("MMMM DD, YYYY") }}
            </div>
        </header>

        <div class="blog-article">
            {{ content | safe }}
        </div>
    </article>
</main>
