<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ seoTitle | default(homepage.seoTitle) }}</title>
    <meta name="description" content="{{ seoDescription | default(homepage.seoDescription) }}">
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large">
    <meta property="og:title" content="{{ seoTitle | default(homepage.seoTitle) }}">
    <meta property="og:description" content="{{ seoDescription | default(homepage.seoDescription) }}">
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="IT Project Cost Calculator">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    
    {% block head %}{% endblock %}
</head>
<body>
    <header id="site-header">
        <div class="header-inner">
            <a href="/" class="logo">
                <span class="logo-icon">⚡</span>
                <span class="logo-text">IT Project Cost Calculator</span>
            </a>
            <nav class="header-nav">
                <a href="/" class="nav-link {% if page.url == '/' %}active{% endif %}" id="nav-home">All Calculators</a>
                <a href="/blog/" class="nav-link {% if '/blog/' in page.url %}active{% endif %}" id="nav-blog">Blog</a>
                <a href="mailto:nilesh.shivlab@gmail.com?subject=Quote Request" class="nav-link btn-nav-cta" id="nav-contact">Get a Quote</a>
            </nav>
            <button class="mobile-menu-btn" id="mobile-menu-btn" aria-label="Toggle menu">
                <span></span><span></span><span></span>
            </button>
        </div>
    </header>

    {% block content %}
    {{ content | safe }}
    {% endblock %}

    <footer id="site-footer">
        <div class="footer-inner">
            <div class="footer-brand"><span class="logo-icon">⚡</span> IT Project Cost Calculator</div>
            <p class="footer-note">Free estimation tool for IT project budgeting. All estimates are approximate ranges based on industry standards.</p>
            <p class="footer-copy">&copy; 2025 IT Project Cost Calculator. All rights reserved.</p>
        </div>
    </footer>

    {% block scripts %}{% endblock %}
</body>
</html>
