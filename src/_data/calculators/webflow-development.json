        {
          "label": "Minor custom code",
          "cost": 500
        },
        {
          "label": "Extensive custom code",
          "cost": 2000
        }
      ]
    },
    {
      "id": "wf6",
      "label": "Third-party Integrations",
      "type": "checkbox",
      "options": [
        {
          "label": "Analytics",
          "cost": 200
        },
        {
          "label": "CRM integration",
          "cost": 800
        },
        {
          "label": "Payment processing",
          "cost": 600
        },
        {
          "label": "Marketing automation",
          "cost": 500
